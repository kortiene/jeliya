{
  "@@locale": "en",
  "bootSyncing": "Syncing…",
  "@bootSyncing": {
    "description": "Boot-screen status line while the app is connected to the local daemon and syncing state. Ellipsis (…) signals ongoing activity — keep an equivalent ongoing-progress cue."
  },
  "bootNotConnected": "Not connected.",
  "@bootNotConnected": {
    "description": "Boot-screen status line when the connection to the local daemon is down. Short declarative sentence with trailing period."
  },
  "bootContactingDaemon": "Contacting daemon…",
  "@bootContactingDaemon": {
    "description": "Boot-screen status line while connecting or reconnecting to the local background daemon. 'daemon' is the technical term for the background process (jeliyad); translate it only if your locale has an established equivalent for this software term, otherwise keep 'daemon'. Ellipsis signals ongoing activity."
  },
  "bootRetryingHint": "Retrying with backoff — start jeliyad or pass ?daemon=<port>.",
  "@bootRetryingHint": {
    "description": "Hint shown under the boot status only while the app is reconnecting with retries. 'jeliyad' (the daemon binary name) and '?daemon=<port>' (a literal URL query parameter, <port> included) are never-translate protocol tokens — copy them verbatim, unchanged. The em dash (—) separates the status from the suggested fix."
  },
  "bootCouldNotStart": "Could not start",
  "@bootCouldNotStart": {
    "description": "Headline of the desktop boot-failure screen. No trailing punctuation; a failure summary and a monospace technical detail line render below it."
  },
  "bootStartingDaemon": "starting the daemon…",
  "@bootStartingDaemon": {
    "description": "Desktop boot progress line while the app launches its bundled background daemon. Intentionally lowercase (renders mid-screen as a quiet status); keep lowercase where the locale allows. Ellipsis signals ongoing activity. 'daemon' is the technical term for the background process."
  },
  "bootAdoptedDaemon": "adopted a running daemon (pid {pid}) on :{port}",
  "@bootAdoptedDaemon": {
    "description": "Desktop boot progress line when the app attaches to an already-running daemon instead of starting a new one. Intentionally lowercase quiet status. {pid} is the daemon's numeric process id; {port} is the local TCP port — the colon before {port} is host:port notation and must stay directly attached to the number.",
    "placeholders": {
      "pid": {
        "type": "int",
        "example": "8412"
      },
      "port": {
        "type": "int",
        "example": "4242"
      }
    }
  },
  "bootDaemonUp": "daemon up (pid {pid}) on :{port}, connecting…",
  "@bootDaemonUp": {
    "description": "Desktop boot progress line once the bundled daemon has started and the app begins connecting to it. Intentionally lowercase quiet status; ellipsis signals ongoing activity. {pid} is the daemon's numeric process id; {port} is the local TCP port — the colon before {port} is host:port notation and must stay directly attached to the number.",
    "placeholders": {
      "pid": {
        "type": "int",
        "example": "8412"
      },
      "port": {
        "type": "int",
        "example": "4242"
      }
    }
  },
  "bootBinaryNotFound": "jeliyad binary not found — set JELIYAD_BIN or run `cargo build` in the repo.",
  "@bootBinaryNotFound": {
    "description": "Desktop boot failure when the daemon executable is missing (developer-facing fix hint). 'jeliyad' (binary name), 'JELIYAD_BIN' (environment variable) and '`cargo build`' (shell command, backticks included) are never-translate tokens — copy them verbatim. The em dash (—) separates the problem from the fix."
  },
  "bootEvictingIncumbent": "replacing an incompatible daemon with the bundled one…",
  "@bootEvictingIncumbent": {
    "description": "Desktop boot progress line while the version-skew rule stops an incompatible already-running daemon and starts the app's bundled one in its place. Intentionally lowercase quiet status; ellipsis signals ongoing activity."
  },
  "bootProtocolMismatch": "The daemon speaks protocol v{actual} but this app requires v{expected} — update the app or the daemon, then retry.",
  "@bootProtocolMismatch": {
    "description": "Hard boot-failure message when the running daemon's protocol version is incompatible with this app. {actual} is the daemon's protocol version number, {expected} the version this app requires; both render after a literal lowercase 'v' (e.g. 'v3') — keep the v-number pattern attached. The em dash (—) separates the diagnosis from the remedy. 'daemon' is the technical term for the background process.",
    "placeholders": {
      "actual": {
        "type": "int",
        "example": "2"
      },
      "expected": {
        "type": "int",
        "example": "3"
      }
    }
  },
  "bootDaemonStartFailed": "The bundled daemon could not be started on this machine.",
  "@bootDaemonStartFailed": {
    "description": "Boot-failure summary (classified bring-up failure) when launching the bundled daemon failed. The raw exception text renders separately below as a monospace technical detail line, so keep this line a plain-language summary."
  },
  "bootDaemonConnectTimeout": "The daemon started but did not accept a connection in time.",
  "@bootDaemonConnectTimeout": {
    "description": "Boot-failure summary (classified bring-up failure) when the daemon launched but the app's connection attempt timed out. The raw exception text renders separately below as a monospace technical detail line, so keep this line a plain-language summary."
  },
  "bootFailedGeneric": "An unexpected failure interrupted start-up.",
  "@bootFailedGeneric": {
    "description": "Fallback boot-failure summary for unclassified start-up errors. The raw exception text renders separately below as a monospace technical detail line, so keep this line a plain-language summary."
  },
  "composerMessagePlaceholder": "Message {roomName}",
  "@composerMessagePlaceholder": {
    "description": "Placeholder text AND accessible label of the message input in the composer bar at the bottom of a room. {roomName} is the room's display name, inserted verbatim (e.g. a room called 'Build Iroh Rooms MVP' reads 'Message Build Iroh Rooms MVP').",
    "placeholders": {
      "roomName": {
        "type": "String",
        "example": "Build Iroh Rooms MVP"
      }
    }
  },
  "composerSendMessage": "Send message",
  "@composerSendMessage": {
    "description": "Accessible label (screen-reader name) of the send button in the composer bar. The button itself visually shows only an arrow glyph (➤), so this text is what assistive tech announces."
  },
  "composerShareAFile": "Share a file",
  "@composerShareAFile": {
    "description": "Tooltip and accessible label of the file-share button in the composer bar, which opens the desktop file picker. The button itself visually shows only the ⎘ glyph."
  },
  "composerHint": "Enter to send · Shift+Enter for a new line · ⎘ to share a file",
  "@composerHint": {
    "description": "Keyboard-hint line shown under the composer bar. 'Enter' and 'Shift+Enter' are keyboard key names — translate them the way keys are conventionally named in your locale. '⎘' is the literal glyph shown on the file-share button and must be kept as-is. The '·' middle dots are separators between the three hints; keep them (with the surrounding spaces) unless your locale uses a different list separator."
  },
  "composerSharingFile": "Sharing file…",
  "@composerSharingFile": {
    "description": "Replaces the keyboard-hint line under the composer bar while a file share is in flight (progress state). Ends with a single ellipsis character (…), not three periods."
  },
  "errPeerUnreachableTitle": "Couldn't reach the inviter",
  "@errPeerUnreachableTitle": {
    "description": "Error card headline: joining via an invite failed because the inviter (the room admin) could not be reached over the network in time. Short, plain-language, no blame."
  },
  "errPeerUnreachableMessage": "The invite is readable, but this device could not reach the room admin in time.",
  "@errPeerUnreachableMessage": {
    "description": "Error card explanation under 'Couldn't reach the inviter'. Clarifies the invite itself parsed fine; the network hop to the room admin timed out."
  },
  "errPeerUnreachableAction": "Ask the inviter to keep the room open, then retry. A fresh combined invite can help if the address changed.",
  "@errPeerUnreachableAction": {
    "description": "Suggested next step for the unreachable-inviter error. 'Combined invite' is a product term: an invite that bundles the ticket with fresh network address info."
  },
  "errBadTicketTitle": "This invite can't be used",
  "@errBadTicketTitle": {
    "description": "Error card headline: the invite's ticket is invalid for this user. 'Invite' is the user-facing word; the underlying credential is called a ticket."
  },
  "errBadTicketMessage": "The ticket is invalid for this identity, malformed, or no longer matches the room invite.",
  "@errBadTicketMessage": {
    "description": "Error card explanation for an unusable invite. 'Ticket' is the product term for the credential inside an invite; 'identity' is the user's cryptographic identity on this device."
  },
  "errBadTicketAction": "Ask for a new invite generated for your current identity ID.",
  "@errBadTicketAction": {
    "description": "Suggested next step for an unusable invite. 'Identity ID' is the user's cryptographic identity identifier shown in the app; keep the term consistent with Settings."
  },
  "errTicketExpiredTitle": "This invite expired",
  "@errTicketExpiredTitle": {
    "description": "Error card headline: the invite's ticket passed its expiry time and was rejected by the room."
  },
  "errTicketExpiredMessage": "The room rejected the ticket because its expiry time has passed.",
  "@errTicketExpiredMessage": {
    "description": "Error card explanation for an expired invite. 'Ticket' is the product term for the credential inside an invite."
  },
  "errTicketExpiredAction": "Ask the inviter to generate a fresh ticket.",
  "@errTicketExpiredAction": {
    "description": "Suggested next step for an expired invite: request a newly generated ticket from the person who invited you."
  },
  "errRoomNotOpenTitle": "Open the room first",
