    "description": "Error card headline: the room's records do not list this user as an active member, so the action was refused."
  },
  "errNotAMemberMessage": "The signed room history does not currently admit this identity as an active member.",
  "@errNotAMemberMessage": {
    "description": "Error card explanation for the not-a-member error. 'Signed room history' is a protocol concept: the cryptographically signed membership log; 'identity' is the user's cryptographic identity."
  },
  "errNotAMemberAction": "Use a valid invite for this identity or ask the room owner to re-add you.",
  "@errNotAMemberAction": {
    "description": "Suggested next step for the not-a-member error: two alternatives, joined with 'or'."
  },
  "errRoomUnknownTitle": "This room isn't local yet",
