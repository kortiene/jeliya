    "description": "Error card headline: this device has no local copy of the room's history, so it cannot open the room. 'Local' means stored on this device."
  },
  "errRoomUnknownMessage": "The daemon does not have enough room history to open this room.",
  "@errRoomUnknownMessage": {
    "description": "Error card explanation for an unknown room. 'Daemon' is a never-translate protocol/product term (the local background process)."
  },
  "errRoomUnknownAction": "Join with an invite, or open the room with a reachable peer hint.",
  "@errRoomUnknownAction": {
    "description": "Suggested next step for an unknown room. 'Peer hint' is a product term: address information for a reachable member that helps the device find the room."
  },
  "errFileUnauthorizedTitle": "Not authorized for this file",
  "@errFileUnauthorizedTitle": {
    "description": "Error card headline: a file download was refused because this user is not authorized for the file."
  },
  "errFileUnauthorizedMessage": "Every reachable provider refused the transfer because the signed history does not admit this identity for it.",
  "@errFileUnauthorizedMessage": {
    "description": "Error card explanation for an unauthorized file fetch. 'Provider' is a product term: a device that can serve the file; 'signed history' is the cryptographically signed room record; 'identity' is the user's cryptographic identity."
  },
  "errFileUnauthorizedAction": "Ask the sender to re-share the file or re-invite you, then retry.",
  "@errFileUnauthorizedAction": {
    "description": "Suggested next step for an unauthorized file fetch: two alternatives from the sender, then retry."
  },
  "errHashMismatchTitle": "Security check failed",
  "@errHashMismatchTitle": {
    "description": "Error card headline: downloaded file bytes failed the cryptographic hash check. Serious security tone; not retryable with the same copy."
  },
  "errHashMismatchMessage": "The fetched bytes did not match the file hash. This is a hard stop — the copy is discarded, never shown.",
  "@errHashMismatchMessage": {
    "description": "Error card explanation for a failed file integrity check. 'Hard stop' means the app refuses to proceed at all; the downloaded copy is deleted and never displayed. Contains an em dash (—); keep the firm, security-conscious tone."
  },
  "errHashMismatchAction": "Ask the sender to re-share the file. Do not retry the same copy.",
  "@errHashMismatchAction": {
    "description": "Suggested next step after a failed integrity check. The second sentence is a firm prohibition — retrying the same copy would fail again and could be unsafe."
  },
