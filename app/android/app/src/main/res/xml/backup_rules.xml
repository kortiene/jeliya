<?xml version="1.0" encoding="utf-8"?>
<!--
  API 23-30 backup rules. Jeliya opts out globally in the manifest and also
  excludes every app-private domain explicitly. The file-domain exclusion is
  especially important for an identity created by an older build under
  files/engine before it is migrated to noBackupFilesDir.
-->
<full-backup-content>
    <exclude domain="root" path="." />
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
