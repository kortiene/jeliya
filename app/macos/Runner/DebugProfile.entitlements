<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Walking-skeleton dev entitlements. App Sandbox is OFF so the app can spawn
	  the jeliyad sidecar (a subprocess outside the bundle) and connect to it on
	  loopback. This is the Phase 0 risk-register mitigation for the dev build;
	  Phase 5 (packaging/signing) replaces it with a co-signed bundled sidecar
	  under a sandbox with network.client/server + sandbox-inherit.
	-->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
</dict>
</plist>
