/target
/dist/
node_modules/
ui/dist/
.jeliya-data*/
.jeliya-demo*/
*.log
.DS_Store
.jeliya-realnet*/
.jeliya-gatea/

# Secret-bearing daemon and agent state. The runner also writes a deny-all
# .gitignore inside every explicit --data-dir as defense in depth.
.jeliya-agent*/
identity.secret
daemon.json

# Release-evidence signing private material is provisioned out of band. Only
# the Ed25519 public SPKI PEM may ever be tracked.
release/evidence-ed25519-private.pem
release/evidence-*.private.pem
release/evidence-*.key
docs/evidence/**/*.private.*

# Legacy pre-rename local state (identity secrets, room dbs) — never commit.
.bantaba-data*/
.bantaba-demo*/
.bantaba-realnet*/
.bantaba-gatea/

# Local agent/tooling metadata; not part of product source.
.claude/

# impeccable live-mode ephemeral session state (config.json + design.json are shared)
.impeccable/live/sessions/

# Android native libs are built by scripts/build-android-libs.mjs, not committed.
app/android/app/src/main/jniLibs/
.gstack/
